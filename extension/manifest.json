{
  "manifest_version": 3,
  "name": "Send to catm",
  "short_name": "catm",
  "description": "Send selected text to catm for on-device text-to-speech reading.",
  "version": "0.1.0",
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png",
    "512": "icons/icon-512.png"
  },
  "permissions": ["contextMenus"],
  "host_permissions": ["https://catm-app.github.io/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
